# Copy this file to .env for local development only.
# Do not commit your real .env file.

# Paste your Railway/Render live database URL here when you want local Flask
# to read the same PostgreSQL database as the deployed website.
# Example format:
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# Optional local/runtime settings:
SECRET_KEY="replace-with-a-long-random-secret"
CLOUDINARY_CLOUD_NAME="your-cloudinary-cloud-name"
CLOUDINARY_API_KEY="your-cloudinary-api-key"
CLOUDINARY_API_SECRET="your-cloudinary-api-secret"

RAZORPAY_KEY_ID="your-razorpay-key-id"
RAZORPAY_KEY_SECRET="your-razorpay-key-secret"
RAZORPAY_WEBHOOK_SECRET="your-razorpay-webhook-secret"

RESEND_API_KEY="your-resend-api-key"
MAIL_FROM="Belt Purse <noreply@belt-purse.com>"
ADMIN_EMAIL="admin@example.com"
SUPPORT_EMAIL="support@example.com"
BASE_URL="http://localhost:5000"

# Keep disabled in production. Enable only for intentional local/manual seeding.
ENABLE_SEED_ROUTE="false"
SEED_ROUTE_KEY="replace-with-a-temporary-random-key"

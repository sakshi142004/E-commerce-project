.env
__pycache__/
*.pyc

# Local databases and generated runtime data must not be deployed by accident.
instance/*.db
instance/*.sqlite
instance/*.sqlite3
*.db
*.sqlite
*.sqlite3
database.sql
backups/

# Production uploads should live in Cloudinary, not in the git repo.
static/uploads/*
!static/uploads/.gitkeep
!static/uploads/blogs/.gitkeep
